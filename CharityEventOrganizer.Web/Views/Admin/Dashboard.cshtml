@model IEnumerable<CharityEventOrganizer.Core.Entities.EventSubmission>

@{
    ViewData["Title"] = "Admin Dashboard";
    var pendingCount = ViewBag.PendingCount ?? 0;
    var publishedCount = ViewBag.PublishedCount ?? 0;
    var recentApprovalCount = ViewBag.RecentApprovalCount ?? 0;
}

<div class="container mb-5">
    <div class="dashboard-header mb-4">
        <h1 class="page-header mb-2">Admin Dashboard</h1>
        <p class="text-muted">Manage event submissions and track platform activity</p>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-4 mb-md-0">
            <div class="stat-card pending-stat">
                <div class="stat-icon">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <div class="stat-content">
                    <h2 class="stat-number">@pendingCount</h2>
                    <p class="stat-label">Pending Submissions</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4 mb-md-0">
            <div class="stat-card published-stat">
                <div class="stat-icon">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-content">
                    <h2 class="stat-number">@publishedCount</h2>
                    <p class="stat-label">Published Events</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card approvals-stat">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h2 class="stat-number">@recentApprovalCount</h2>
                    <p class="stat-label">Recent Approvals</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Pending Submissions -->
        <div class="col-lg-8 mb-4">
            <div class="card dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-tasks mr-2"></i>Pending Event Submissions</h5>
                    <span class="badge badge-pill badge-primary">@pendingCount</span>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="empty-state p-4">
                            <div class="text-center">
                                <i class="fas fa-check-circle empty-icon mb-3"></i>
                                <h5>All caught up!</h5>
                                <p class="text-muted mb-0">There are no pending submissions at this time.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Event Title</th>
                                        <th>Submitted By</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var submission in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="submission-icon mr-3">
                                                        <i class="fas fa-calendar-alt"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0">@submission.Event.Title</h6>
                                                        <small class="text-muted">@submission.Event.Location</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@submission.Submitter.Email</td>
                                            <td>@submission.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <a asp-action="ReviewSubmission" asp-route-id="@submission.Id" class="btn btn-sm btn-primary">
                                                    Review
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="col-lg-4">
            <div class="card dashboard-card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-history mr-2"></i>Recent Activity</h5>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.RecentApprovals == null || !(ViewBag.RecentApprovals as IEnumerable<dynamic>).Any())
                    {
                        <div class="p-4 text-center">
                            <p class="text-muted mb-0">No recent activity to display.</p>
                        </div>
                    }
                    else
                    {
                        <div class="activity-timeline">
                            @foreach (var approval in ViewBag.RecentApprovals)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                    <div class="activity-content">
                                        <p class="activity-text mb-1">
                                            <strong>Event Approved:</strong> @approval.Event.Title
                                        </p>
                                        <p class="activity-date mb-0">
                                            @(approval.ReviewedAt?.ToString("MMM dd, yyyy"))
                                        </p>
                                    </div>
                                </div>
                            }

                            <!-- Sample User Activity -->
                            <div class="activity-item">
                                <div class="activity-icon user-icon">
                                    <i class="fas fa-user-plus"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-text mb-1">
                                        <strong>New User:</strong> john.doe@example.com registered
                                    </p>
                                    <p class="activity-date mb-0">
                                        @DateTime.Now.AddDays(-1).ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="activity-icon sponsor-icon">
                                    <i class="fas fa-handshake"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-text mb-1">
                                        <strong>New Sponsor:</strong> Local Business Association
                                    </p>
                                    <p class="activity-date mb-0">
                                        @DateTime.Now.AddDays(-2).ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card dashboard-card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-bolt mr-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3 mb-md-0">
                            <a href="#" class="quick-action-card">
                                <div class="quick-action-icon">
                                    <i class="fas fa-plus-circle"></i>
                                </div>
                                <h6>Add Sponsor</h6>
                            </a>
                        </div>
                        <div class="col-md-3 mb-3 mb-md-0">
                            <a href="#" class="quick-action-card">
                                <div class="quick-action-icon">
                                    <i class="fas fa-user-cog"></i>
                                </div>
                                <h6>Manage Users</h6>
                            </a>
                        </div>
                        <div class="col-md-3 mb-3 mb-md-0">
                            <a href="#" class="quick-action-card">
                                <div class="quick-action-icon">
                                    <i class="fas fa-chart-line"></i>
                                </div>
                                <h6>View Reports</h6>
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="#" class="quick-action-card">
                                <div class="quick-action-icon">
                                    <i class="fas fa-cog"></i>
                                </div>
                                <h6>Settings</h6>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Sponsors -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-handshake mr-2"></i>Recent Sponsors</h5>
                    <a href="#" class="btn btn-sm btn-light">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Sponsor</th>
                                    <th>Contact</th>
                                    <th>Events</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="sponsor-logo mr-3">
                                                <i class="fas fa-building"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">Local Business Association</h6>
                                                <small class="text-muted">Business</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>contact@lba.org</td>
                                    <td>3</td>
                                    <td><span class="badge badge-success">Active</span></td>
                                </tr>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="sponsor-logo mr-3">
                                                <i class="fas fa-university"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">Community Foundation</h6>
                                                <small class="text-muted">Non-profit</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>info@communityfoundation.org</td>
                                    <td>5</td>
                                    <td><span class="badge badge-success">Active</span></td>
                                </tr>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="sponsor-logo mr-3">
                                                <i class="fas fa-store"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">Downtown Shops</h6>
                                                <small class="text-muted">Retail</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>support@downtownshops.com</td>
                                    <td>2</td>
                                    <td><span class="badge badge-warning">Pending</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Stat Cards */
        .stat-card {
            display: flex;
            align-items: center;
            background-color: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            height: 100%;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-right: 1rem;
            color: white;
        }

        .pending-stat .stat-icon {
            background: linear-gradient(135deg, #F39C12, #E67E22);
        }

        .published-stat .stat-icon {
            background: linear-gradient(135deg, #2ECC71, #27AE60);
        }

        .approvals-stat .stat-icon {
            background: linear-gradient(135deg, #9B59B6, #8E44AD);
        }

        .stat-content {
            flex: 1;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
            line-height: 1;
        }

        .stat-label {
            color: #7F8C8D;
            margin-bottom: 0;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Dashboard Cards */
        .dashboard-card {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            border: none;
            margin-bottom: 1.5rem;
        }

            .dashboard-card .card-header {
                background-color: #8E44AD;
                color: white;
                padding: 1rem 1.25rem;
                border-bottom: none;
            }

                .dashboard-card .card-header .badge {
                    background-color: white;
                    color: #8E44AD;
                    font-weight: 600;
                }

        /* Activity Timeline */
        .activity-timeline {
            padding: 1.25rem;
        }

        .activity-item {
            display: flex;
            padding-bottom: 1.25rem;
            margin-bottom: 1.25rem;
            border-bottom: 1px solid #EEE;
            position: relative;
        }

            .activity-item:last-child {
                padding-bottom: 0;
                margin-bottom: 0;
                border-bottom: none;
            }

        .activity-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin-right: 1rem;
            background: linear-gradient(135deg, #2ECC71, #27AE60);
        }

            .activity-icon.user-icon {
                background: linear-gradient(135deg, #3498DB, #2980B9);
            }

            .activity-icon.sponsor-icon {
                background: linear-gradient(135deg, #F39C12, #E67E22);
            }

        .activity-content {
            flex: 1;
        }

        .activity-text {
            font-size: 0.95rem;
        }

        .activity-date {
            font-size: 0.8rem;
            color: #7F8C8D;
        }

        /* Table Styling */
        .table {
            margin-bottom: 0;
        }

            .table th {
                border-top: none;
                font-weight: 600;
                color: #7F8C8D;
                text-transform: uppercase;
                font-size: 0.8rem;
                letter-spacing: 1px;
            }

            .table td {
                vertical-align: middle;
            }

        .submission-icon, .sponsor-logo {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background-color: rgba(142, 68, 173, 0.1);
            color: #8E44AD;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        /* Empty State */
        .empty-state {
            padding: 2rem;
            text-align: center;
        }

        .empty-icon {
            font-size: 3rem;
            color: #27AE60;
            margin-bottom: 1rem;
        }

        /* Quick Action Cards */
        .quick-action-card {
            display: block;
            background-color: white;
            border-radius: 10px;
            padding: 1.25rem;
            text-align: center;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            height: 100%;
            color: #2C3E50;
            text-decoration: none;
        }

            .quick-action-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
                text-decoration: none;
                color: #8E44AD;
            }

        .quick-action-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: rgba(142, 68, 173, 0.1);
            color: #8E44AD;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin: 0 auto 1rem;
            transition: all 0.3s ease;
        }

        .quick-action-card:hover .quick-action-icon {
            background-color: #8E44AD;
            color: white;
        }

        .quick-action-card h6 {
            margin-bottom: 0;
            font-weight: 600;
        }

        /* Badge styling */
        .badge {
            padding: 0.5em 0.75em;
            font-weight: 600;
            border-radius: 4px;
        }

        .badge-success {
            background-color: #27AE60;
        }

        .badge-warning {
            background-color: #F39C12;
            color: white;
        }

        .badge-danger {
            background-color: #E74C3C;
        }

        .badge-primary {
            background-color: #8E44AD;
        }

        /* Button styling */
        .btn-light {
            background-color: rgba(255, 255, 255, 0.2);
            color: white;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-light:hover {
                background-color: rgba(255, 255, 255, 0.3);
                color: white;
            }
    </style>
}