@model IEnumerable<CharityEventOrganizer.Core.Entities.Event>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="hero-title mb-3">Make an Impact with Your Events</h1>
                <p class="hero-subtitle mb-4">Join our community of changemakers organizing events that matter. Connect with causes, sponsors, and volunteers to create positive change.</p>
                <div class="hero-buttons">
                    <a asp-controller="Events" asp-action="Create" class="btn btn-light btn-lg">
                        <i class="fas fa-calendar-plus mr-2"></i>Create Event
                    </a>
                    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-light btn-lg ml-3">
                        <i class="fas fa-search mr-2"></i>Browse Events
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image">
                    <img src="/images/hero-illustration.svg" alt="Charity Events" class="img-fluid">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- How It Works Section -->
<div class="container section-padding">
    <div class="section-header text-center mb-5">
        <h2>How It Works</h2>
        <p class="text-muted">Create and manage charity events in just a few simple steps</p>
    </div>

    <div class="row process-steps">
        <div class="col-md-3 mb-4 mb-md-0">
            <div class="process-card">
                <div class="process-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h4>1. Register</h4>
                <p>Create your account to get started with our platform</p>
            </div>
        </div>
        <div class="col-md-3 mb-4 mb-md-0">
            <div class="process-card">
                <div class="process-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <h4>2. Create Event</h4>
                <p>Submit your event details for review and approval</p>
            </div>
        </div>
        <div class="col-md-3 mb-4 mb-md-0">
            <div class="process-card">
                <div class="process-icon">
                    <i class="fas fa-handshake"></i>
                </div>
                <h4>3. Connect</h4>
                <p>Find sponsors and volunteers for your cause</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="process-card">
                <div class="process-icon">
                    <i class="fas fa-bullhorn"></i>
                </div>
                <h4>4. Promote</h4>
                <p>Share your event and make a difference</p>
            </div>
        </div>
    </div>
</div>

<!-- Featured Events Section -->
<div class="container section-padding">
    <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h2>Featured Events</h2>
        <a asp-controller="Events" asp-action="Index" class="btn btn-outline-primary">
            View All <i class="fas fa-arrow-right ml-1"></i>
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <h3>No Events Yet</h3>
            <p class="text-muted">There are no published events yet. Be the first to create one!</p>
            <a asp-controller="Events" asp-action="Create" class="btn btn-primary mt-3">
                <i class="fas fa-plus-circle mr-2"></i>Create Event
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model.Take(3))
            {
                <div class="col-md-4 mb-4">
                    <div class="event-card">
                        <div class="event-card-image">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title">
                            }
                            else
                            {
                                <img src="/images/default-event.jpg" alt="Default Event Image">
                            }
                            <div class="event-date-badge">
                                <span class="month">@item.EventDate.ToString("MMM")</span>
                                <span class="day">@item.EventDate.Day</span>
                            </div>
                        </div>
                        <div class="event-card-body">
                            <div class="event-location">
                                <i class="fas fa-map-marker-alt mr-1"></i> @item.Location
                            </div>
                            <h5 class="event-title">@item.Title</h5>
                            <p class="event-description">@item.Description.Substring(0, Math.Min(100, item.Description.Length))...</p>
                        </div>
                        <div class="event-card-footer">
                            <div class="event-organizer">
                                @if (string.IsNullOrEmpty(item.Organizer?.ProfilePictureUrl))
                                {
                                    <div class="organizer-avatar">
                                        @(string.IsNullOrEmpty(item.Organizer?.FirstName) ? "U" : item.Organizer.FirstName.Substring(0, 1))
                                    </div>
                                }
                                else
                                {
                                    <img src="@item.Organizer.ProfilePictureUrl" alt="@item.Organizer.FirstName" class="organizer-img">
                                }
                                <span class="organizer-name">@(string.IsNullOrEmpty(item.Organizer?.FirstName) ? "User" : item.Organizer.FirstName)</span>
                            </div>
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Impact Stats Section -->
<div class="impact-section">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="text-white">Our Impact</h2>
            <p class="text-white-50">Together we're making a difference</p>
        </div>

        <div class="row text-center">
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-counter">
                    <div class="counter">500+</div>
                    <p>Events Organized</p>
                </div>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-counter">
                    <div class="counter">$2M+</div>
                    <p>Funds Raised</p>
                </div>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-counter">
                    <div class="counter">10K+</div>
                    <p>Volunteers</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-counter">
                    <div class="counter">300+</div>
                    <p>Communities Helped</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Testimonials Section -->
<div class="container section-padding">
    <div class="section-header text-center mb-5">
        <h2>What Organizers Say</h2>
        <p class="text-muted">Hear from people who have used our platform</p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="testimonial-card">
                <div class="testimonial-content">
                    <p>"This platform made it so easy to organize our community cleanup event. We raised more funds than expected and had a great turnout!"</p>
                </div>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">
                        <span>JD</span>
                    </div>
                    <div class="testimonial-info">
                        <h5>Jane Doe</h5>
                        <p>Environmental Activist</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="testimonial-card">
                <div class="testimonial-content">
                    <p>"I was amazed by how quickly we found sponsors for our charity run. The platform connected us with local businesses who were eager to support our cause."</p>
                </div>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">
                        <span>MS</span>
                    </div>
                    <div class="testimonial-info">
                        <h5>Michael Smith</h5>
                        <p>Marathon Organizer</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="testimonial-card">
                <div class="testimonial-content">
                    <p>"As a first-time event organizer, I appreciated how intuitive the platform is. From submission to promotion, everything was straightforward and well-designed."</p>
                </div>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">
                        <span>AL</span>
                    </div>
                    <div class="testimonial-info">
                        <h5>Amy Lee</h5>
                        <p>Community Leader</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="container section-padding">
    <div class="cta-card">
        <div class="row align-items-center">
            <div class="col-lg-8 mb-4 mb-lg-0">
                <h3 class="mb-2">Ready to make a difference?</h3>
                <p class="mb-0">Join thousands of organizers who are creating impactful charity events</p>
            </div>
            <div class="col-lg-4 text-lg-right">
                <a asp-controller="Events" asp-action="Create" class="btn btn-light btn-lg">
                    <i class="fas fa-plus-circle mr-2"></i>Create Event
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, #8E44AD, #9B59B6);
            color: white;
            padding: 5rem 0;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/pattern.svg');
            background-size: cover;
            opacity: 0.05;
        }

        .hero-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: white;
        }

        .hero-subtitle {
            font-size: 1.1rem;
            max-width: 500px;
            color: rgba(255, 255, 255, 0.9);
        }

        .hero-buttons .btn {
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .hero-buttons .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .hero-image {
            animation: float 3s ease-in-out infinite;
        }

        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }

        /* Section Padding */
        .section-padding {
            padding: 5rem 0;
        }

        /* Section Headers */
        .section-header h2 {
            color: #8E44AD;
            font-weight: 700;
            position: relative;
            display: inline-block;
            margin-bottom: 1rem;
        }

        .section-header h2::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 50px;
            height: 3px;
            background: linear-gradient(135deg, #8E44AD, #9B59B6);
            border-radius: 3px;
        }

        .section-header.text-center h2::after {
            left: 50%;
            transform: translateX(-50%);
        }

        /* Process Cards */
        .process-steps {
            position: relative;
        }

        .process-card {
            background-color: white;
            border-radius: 12px;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            height: 100%;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .process-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        .process-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #8E44AD, #9B59B6);
            color: white;
            font-size: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }

        .process-card h4 {
            font-weight: 600;
            margin-bottom: 1rem;
            color: #2C3E50;
        }

        .process-card p {
            color: #7F8C8D;
            margin-bottom: 0;
        }

        /* Event Cards */
        .event-card {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            height: 100%;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .event-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        .event-card-image {
            height: 200px;
            position: relative;
            overflow: hidden;
        }

        .event-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .event-card:hover .event-card-image img {
            transform: scale(1.1);
        }

        .event-date-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background-color: #8E44AD;
            color: white;
            border-radius: 8px;
            padding: 5px 10px;
            text-align: center;
            font-size: 0.8rem;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        }

        .event-date-badge .month {
            display: block;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            margin-bottom: 2px;
        }

        .event-date-badge .day {
            display: block;
            font-weight: 700;
            font-size: 1.2rem;
            line-height: 1;
        }

        .event-card-body {
            padding: 1.5rem;
        }

        .event-location {
            display: inline-block;
            background-color: rgba(142, 68, 173, 0.1);
            color: #8E44AD;
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 0.8rem;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .event-title {
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .event-description {
            color: #7F8C8D;
            margin-bottom: 0;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .event-card-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #EEE;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .event-organizer {
            display: flex;
            align-items: center;
        }

        .organizer-avatar, .organizer-img {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            margin-right: 10px;
            background-color: #8E44AD;
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .organizer-img {
            object-fit: cover;
        }

        .organizer-name {
            font-size: 0.9rem;
            color: #7F8C8D;
        }

        /* Empty State */
        .empty-state {
            background-color: white;
            border-radius: 12px;
            padding: 3rem;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .empty-state-icon {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background-color: rgba(142, 68, 173, 0.1);
            color: #8E44AD;
            font-size: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }

        .empty-state h3 {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        /* Impact Section */
        .impact-section {
            background: linear-gradient(135deg, #2C3E50, #34495E);
            color: white;
            padding: 5rem 0;
            position: relative;
        }

        .stat-counter {
            padding: 1rem;
        }

        .counter {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #8E44AD;
        }

        .stat-counter p {
            font-size: 1.1rem;
            margin-bottom: 0;
            color: white;
        }

        /* Testimonial Cards */
        .testimonial-card {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            height: 100%;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .testimonial-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        .testimonial-content {
            padding: 2rem;
            position: relative;
        }

        .testimonial-content::before {
            content: "";
            position: absolute;
            top: 10px;
            left: 10px;
            font-size: 60px;
            line-height: 1;
            color: rgba(142, 68, 173, 0.1);
            font-family: Georgia, serif;
        }

        .testimonial-content p {
            position: relative;
            z-index: 1;
            font-style: italic;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            padding: 1rem 2rem;
            background-color: rgba(142, 68, 173, 0.05);
        }

        .testimonial-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: #8E44AD;
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
        }

        .testimonial-info h5 {
            margin-bottom: 0;
            font-weight: 600;
        }

        .testimonial-info p {
            margin-bottom: 0;
            color: #7F8C8D;
            font-size: 0.9rem;
        }

        /* Call to Action */
        .cta-card {
            background: linear-gradient(135deg, #8E44AD, #9B59B6);
            color: white;
            border-radius: 12px;
            padding: 3rem;
            box-shadow: 0 10px 30px rgba(142, 68, 173, 0.3);
        }

        .cta-card h3 {
            font-weight: 700;
        }

        .cta-card .btn-light {
            background-color: white;
            color: #8E44AD;
            font-weight: 600;
            border-radius: 8px;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
        }

        .cta-card .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        /* Responsive Adjustments */
        @@media (max-width: 768px) {
            .hero-section {
                padding: 3rem 0;
            }

            .hero-title {
                font-size: 2rem;
            }

            .section-padding {
                padding: 3rem 0;
            }

            .cta-card {
                padding: 2rem;
            }
        }
    </style>
}