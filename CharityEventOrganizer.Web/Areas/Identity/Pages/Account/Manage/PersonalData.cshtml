@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h1 class="page-header">Manage your account</h1>
<p class="text-muted mb-4">Change your account settings</p>

<div class="row">
    <div class="col-md-3">
        <partial name="_ManageNav" />
    </div>
    <div class="col-md-9">
        <div class="card">
            <div class="card-header" style="background-color: #8E44AD; color: white;">
                <h4 class="mb-0">@ViewData["Title"]</h4>
            </div>
            <div class="card-body">
                <p>Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
                <p><strong class="text-danger">Deleting this data will permanently remove your account, and this cannot be recovered.</strong></p>

                <div class="d-flex mt-4">
                    <form id="download-data" asp-page="DownloadPersonalData" method="post">
                        <button class="btn btn-primary mr-3" type="submit">Download</button>
                    </form>

                    <a id="delete" class="btn btn-danger" asp-page="DeletePersonalData">Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}